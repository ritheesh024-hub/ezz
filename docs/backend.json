
{
  "entities": {
    "AdminProfile": {
      "title": "Admin Profile",
      "description": "Details for administrative users authorized to access the Ezzy Bites dashboard",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the administrator"
        },
        "role": {
          "type": "string",
          "enum": ["admin"],
          "description": "The user role, must be 'admin'"
        }
      },
      "required": ["email", "role"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Customer profile linked to their mobile number",
      "type": "object",
      "properties": {
        "phone": { "type": "string", "description": "The verified mobile number" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "lastOrderAt": { "type": "string", "format": "date-time" },
        "orderCount": { "type": "number" }
      },
      "required": ["phone"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order for Ezzy Bites food items",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "address": { "type": "string" },
        "instructions": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "subtotal": { "type": "number" },
        "deliveryFee": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Preparing", "Out for Delivery", "Delivered", "Cancelled"] },
        "paymentMethod": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "customerPhone", "address", "items", "total", "status", "createdAt"]
    },
    "FoodItem": {
      "title": "Food Item",
      "description": "A menu item available for purchase at Ezzy Bites",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "isVeg": { "type": "boolean" },
        "rating": { "type": "number" },
        "isAvailable": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "imageUrl", "isAvailable"]
    },
    "OTPCode": {
      "title": "OTP Code",
      "description": "Temporary 4-digit verification code for phone authentication",
      "type": "object",
      "properties": {
        "otp": { "type": "string" },
        "expiresAt": { "type": "number" },
        "createdAt": { "type": "object" }
      },
      "required": ["otp", "expiresAt"]
    }
  },
  "auth": {
    "providers": ["password", "phone"]
  },
  "firestore": {
    "/admins/{userId}": {
      "schema": "#/entities/AdminProfile",
      "description": "Restricted collection for admin user metadata"
    },
    "/users/{phone}": {
      "schema": "#/entities/UserProfile",
      "description": "Customer profiles keyed by phone number"
    },
    "/orders/{orderId}": {
      "schema": "#/entities/Order",
      "description": "Collection of customer orders"
    },
    "/products/{productId}": {
      "schema": "#/entities/FoodItem",
      "description": "Collection of dynamic menu items (products)"
    },
    "/otp_codes/{phone}": {
      "schema": "#/entities/OTPCode",
      "description": "Temporary storage for 4-digit OTP codes keyed by phone number"
    }
  }
}
