
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // UTILITY FUNCTIONS
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function getAdminData() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data;
    }
    function isAdmin() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        request.auth.token.email == "sunnyritheesh@gmail.com"
      );
    }
    function isKitchen() {
      return isAdmin() && (request.auth.token.email == "sunnyritheesh@gmail.com" || getAdminData().role == 'kitchen');
    }
    function isCashier() {
      return isAdmin() && (request.auth.token.email == "sunnyritheesh@gmail.com" || getAdminData().role == 'cashier');
    }
    function isMasterAdmin() {
      return isAdmin() && (request.auth.token.email == "sunnyritheesh@gmail.com" || getAdminData().role == 'admin');
    }

    // ADMINS: Master access for setup, read for all authenticated nodes
    match /admins/{userId} {
      allow read: if isAuthenticated();
      allow write: if isMasterAdmin() || (isAuthenticated() && request.auth.token.email == "sunnyritheesh@gmail.com");
    }

    // USERS: Identity protection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
      
      match /notifications/{notifId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) || isAdmin();
      }
      
      match /permissions/{permId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ORDERS: Workflow-based permissions
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isMasterAdmin() 
                    || (isKitchen() && request.resource.data.status == 'confirmed' && resource.data.status == 'orderPlaced')
                    || (isCashier() && request.resource.data.status in ['confirmed', 'outForDelivery', 'delivered'])
                    || (isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.status == 'Cancelled' && resource.data.status in ['orderPlaced', 'confirmed']);
    }

    // PRODUCTS & REVIEWS: Public assets
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // OPERATIONAL COLLECTIONS
    match /coupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /referrals/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    match /favorites/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid);
    }

    match /login_events/{id} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
    }

    match /broadcast_logs/{id} {
      allow read, write: if isAdmin();
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /analytics/{id} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // FALLBACK
    match /{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
